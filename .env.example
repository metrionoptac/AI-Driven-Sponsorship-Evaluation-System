# ============================================================
# Sponsorship Evaluator — Environment Configuration
# Copy to .env and fill in values
# ============================================================

# --- Database ---
DATABASE_URL=postgresql://sponsorship:sponsorship@localhost:5432/sponsorship_db

# --- LLM ---
LLM_ANTHROPIC_API_KEY=sk-ant-...
LLM_OPENAI_API_KEY=sk-...

# --- Pipeline ---
PIPELINE_MODE=copilot

# --- Email Watcher (IMAP) ---
# Set INTAKE_IMAP_HOST to enable email watching
INTAKE_IMAP_HOST=
INTAKE_IMAP_PORT=993
INTAKE_IMAP_USERNAME=
INTAKE_IMAP_PASSWORD=
INTAKE_IMAP_FOLDER=INBOX
INTAKE_IMAP_POLL_INTERVAL_SEC=300
INTAKE_IMAP_USE_IDLE=true

# --- Folder Watcher ---
# Comma-separated list of directories to watch for scanned documents
# INTAKE_WATCH_FOLDERS=["./scans/incoming"]
# INTAKE_PROCESSED_FOLDER=./scans/processed

# --- Deduplication ---
# Set to false for testing (allows re-sending the same document)
INTAKE_DEDUP_ENABLED=true

# --- Storage ---
INTAKE_RAW_DOC_STORAGE_PATH=./documents/raw

# --- App ---
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
